{
  "expo": {
    "name": "AURA",
    "slug": "aura",
    "version": "1.0.4",
    "orientation": "portrait",
    "privacyPolicy": "https://aura-site-3l69adydm-egod21s-projects.vercel.app/privacy-policy",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "EGIntegrations.AURA--ADA-Companion",
      "deploymentTarget": "15.1",
      "buildNumber": "1.0.4",
      "infoPlist": {
        "NSCameraUsageDescription": "AURA needs camera access for facial mimicry training",
        "NSPhotoLibraryUsageDescription": "AURA may access your photo library only when you choose to select an image for app features.",
        "NSPhotoLibraryAddUsageDescription": "AURA may save generated training images to your photo library only when you choose to do so.",
        "NSMicrophoneUsageDescription": "AURA needs microphone access for speech practice",
        "NSSpeechRecognitionUsageDescription": "AURA needs speech recognition for speech and conversation practice",
        "NSFaceIDUsageDescription": "AURA uses Face ID for secure sign-in",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.egintegrations.aura",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-local-authentication",
      "expo-dev-client",
      "expo-speech-recognition",
      [
        "expo-build-properties",
        {
          "android": {
            "useAndroidX": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "enableProguardInReleaseBuilds": true,
            "packagingOptions": {
              "pickFirst": [
                "lib/armeabi-v7a/libc++_shared.so",
                "lib/arm64-v8a/libc++_shared.so",
                "lib/x86/libc++_shared.so",
                "lib/x86_64/libc++_shared.so"
              ]
            },
            "extraProguardRules": "-dontwarn com.android.support.**\n-dontwarn androidx.**"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "de6a7920-284c-40fb-861d-d2d9e28be82b"
      },
      "backendBaseUrl": "",
      "allowOfflineAuthInProduction": true
    },
    "owner": "egintegrations"
  }
}
